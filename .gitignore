# ========================
# 构建产物（colcon / CMake）
# ========================
build/
install/
log/

# 包内嵌套的构建产物
src/*/build/
src/*/install/
src/*/log/
src/hnurm_radar/build/
src/hnurm_radar/install/
src/hnurm_radar/log/

# ========================
# Python 缓存
# ========================
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/

# ========================
# 模型文件（体积大，不入库）
# ========================
*.engine
*.onnx

# ========================
# 点云数据文件（data/*.pcd 通过 Git LFS 管理，不要排除）
# ========================
*.pcd.bak
*.pcd2.bak
target.xyz

# ========================
# data 目录下的备份文件
# ========================
data/*.bak

# ========================
# 运行时生成 / 日志文件
# ========================
MvFGSdkLog/
record/

# ========================
# IDE / 编辑器
# ========================
.vscode/
.idea/
*.swp
*.swo
*~

# ========================
# 系统文件 / 无用文件
# ========================
.DS_Store
Thumbs.db

*.mp4
test_output/
test_output/*.jpg
test_output/*.png
# docs/ 目录现在纳入版本控制
# 排除生成的文档产物
docs/_build/
docs/*.pdf
docs/archive/
docs/tmp/